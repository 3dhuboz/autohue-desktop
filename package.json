{
  "name": "autohue-desktop",
  "version": "1.1.1",
  "description": "AutoHue — AI-powered car photo color sorter for motorsport photographers",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite --config renderer/vite.config.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "electron .",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.0",
    "express": "^5.1.0",
    "jimp": "^0.22.12",
    "multer": "^2.0.1",
    "node-unrar-js": "^2.0.2",
    "onnxruntime-node": "^1.21.0",
    "sql.js": "^1.14.1",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
